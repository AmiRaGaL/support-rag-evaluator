generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Document {
  id          String          @id @default(cuid())
  title       String
  sourceKey   String          @unique
  sourceType  String          @default("markdown")
  sourcePath  String?
  contentHash String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  chunks      DocumentChunk[]
}

model DocumentChunk {
  id         String                       @id @default(cuid())
  documentId String
  chunkIndex Int
  content    String
  tokenCount Int?
  metadata   Json?
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime                     @default(now())
  updatedAt  DateTime                     @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
}

model RagQuery {
  id                  String              @id @default(cuid())
  question            String
  answer              String
  refusal             Boolean             @default(false)
  confidence          Float?
  provider            String
  retrievedChunkCount Int
  latencyMs           Int
  createdAt           DateTime            @default(now())
  retrievedChunks     RagRetrievedChunk[]

  @@index([createdAt])
  @@index([refusal])
}

model RagRetrievedChunk {
  id            String   @id @default(cuid())
  ragQueryId    String
  chunkId       String
  documentId    String
  documentTitle String
  sourceKey     String
  chunkIndex    Int
  similarity    Float
  citationUsed  Boolean  @default(false)
  createdAt     DateTime @default(now())

  ragQuery RagQuery @relation(fields: [ragQueryId], references: [id], onDelete: Cascade)

  @@index([ragQueryId])
  @@index([sourceKey])
  @@index([citationUsed])
}

model EvalRun {
  id                  String           @id @default(cuid())
  name                String
  datasetPath         String
  totalCases          Int
  passedCases         Int
  failedCases         Int
  refusalAccuracy     Float
  citationAccuracy    Float
  answerMatchAccuracy Float
  provider            String
  createdAt           DateTime         @default(now())
  caseResults         EvalCaseResult[]

  @@index([createdAt])
  @@index([provider])
}

model EvalCaseResult {
  id               String   @id @default(cuid())
  evalRunId        String
  caseId           String
  question         String
  type             String
  passed           Boolean
  expectedAnswer   String
  expectedSources  Json
  actualAnswer     String
  actualRefusal    Boolean
  actualConfidence Float?
  actualCitations  Json
  refusalCorrect   Boolean
  citationCorrect  Boolean
  answerMatch      Boolean
  createdAt        DateTime @default(now())

  evalRun EvalRun @relation(fields: [evalRunId], references: [id], onDelete: Cascade)

  @@index([evalRunId])
  @@index([caseId])
  @@index([passed])
  @@index([type])
}
